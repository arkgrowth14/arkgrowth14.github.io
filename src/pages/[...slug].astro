---
// 1. We removed the Wix SEO import. Standard HTML tags are used instead.
import { Head } from "@/components/Head";
import AppRouter from "@/components/Router";

// 2. We removed the Wix Vibe CSS imports because they require a Wix login.
// You can add standard Tailwind or local CSS here later.
import "@/styles/global.css";

// 3. We removed the Wix 'loadSEOTagsServiceConfig' call.
const pageTitle = "Ark Growth | Home";
---

<html lang="en" class="w-full h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <title>{pageTitle}</title>
    <meta name="description" content="Ark Growth - Migrated to GitHub" />

    <Head />
  </head>
  <body class="w-full h-full">
    <div id="root" class="w-full h-full">
      <AppRouter client:only="react" />
    </div>
  </body>
</html>
